# VPS 2 — MinIO seul (docker-compose.minio.yml)
# cp .env.minio.example .env.minio
#
# Utiliser les MÊMES MINIO_ROOT_USER / MINIO_ROOT_PASSWORD
# que MINIO_ACCESS_KEY / MINIO_SECRET_KEY dans le .env du VPS 1

MINIO_ROOT_USER=pdvconnect-minio
MINIO_ROOT_PASSWORD=change-me-minio-secret

MINIO_BUCKET=pdvconnect-backups
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
