APP_NAME=Laravel
APP_ENV=local
APP_KEY=base64:zvz76SleHTgqZSLunqeiRq6WBetM4Ev35j9j58364sY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
# Local dev (docker-compose.yml) : DB_HOST=127.0.0.1 DB_PORT=3307
# VPS Docker (docker-compose.vps.yml) : cp .env.vps.example .env → DB_HOST=mysql
# MinIO VPS 2 : docker-compose.minio.yml + .env.minio.example
# Production AlwaysData / Render :
DB_HOST=mysql-kapelo.alwaysdata.net
DB_PORT=3306
DB_DATABASE=kapelo_pdvconnect
DB_USERNAME=kapelo
DB_PASSWORD=your-alwaysdata-password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

SECURITY_LOGIN_RATE_LIMIT=10,1

# Sauvegardes BDD → MinIO
BACKUP_ENABLED=true
BACKUP_DISK=backups
BACKUP_RETENTION_DAYS=7
BACKUP_SCHEDULE_TIME=02:00
BACKUP_MYSQLDUMP_PATH=mysqldump
BACKUP_PREFIX=pdvconnect
BACKUP_STALE_HOURS=48

MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=pdvconnect-backups
MINIO_REGION=us-east-1
MINIO_USE_PATH_STYLE=true
MINIO_URL=

VITE_APP_NAME="${APP_NAME}"

SMS_API_TOKEN=un-token-secret-long
SMS_DEFAULT_AGENT_ID=1
SMS_DEFAULT_OPERATEUR_ID=1