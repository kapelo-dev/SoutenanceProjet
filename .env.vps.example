# VPS 1 — App + MySQL (docker-compose.vps.yml)
# cp .env.vps.example .env

APP_NAME=PDVConnect
APP_ENV=production
APP_KEY=base64:GENERER_AVEC_php_artisan_key:generate
APP_DEBUG=false
APP_URL=https://ton-domaine.com

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=info

# MySQL (conteneur docker — ne pas changer DB_HOST)
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=pdvconnect
DB_USERNAME=pdvconnect
DB_PASSWORD=change-me-strong-db-password
MYSQL_ROOT_PASSWORD=change-me-root-password

SESSION_DRIVER=database
SESSION_LIFETIME=120
CACHE_STORE=database
QUEUE_CONNECTION=database

APP_PORT=80

# MinIO sur VPS 2 (remplacer par l'IP publique du 2e VPS)
MINIO_ENDPOINT=http://VPS2_IP:9000
MINIO_ACCESS_KEY=pdvconnect-minio
MINIO_SECRET_KEY=change-me-minio-secret
MINIO_BUCKET=pdvconnect-backups
MINIO_REGION=us-east-1
MINIO_USE_PATH_STYLE=true
MINIO_URL=

BACKUP_ENABLED=true
BACKUP_DISK=backups
BACKUP_RETENTION_DAYS=7
BACKUP_SCHEDULE_TIME=02:00
BACKUP_MYSQLDUMP_PATH=mysqldump
BACKUP_PREFIX=pdvconnect
BACKUP_STALE_HOURS=48

SECURITY_AUDIT_LOGGING_ENABLED=true
SECURITY_IP_BLOCKING_ENABLED=true
SECURITY_AUTO_BLOCK_THRESHOLD=10
SECURITY_LOGIN_RATE_LIMIT_ENABLED=true
SECURITY_LOGIN_RATE_LIMIT=10,1

SMS_API_TOKEN=change-me-sms-token
SMS_DEFAULT_AGENT_ID=1
SMS_DEFAULT_OPERATEUR_ID=1
